*.py[cod]
*.pyo
*.so
*.egg
*.egg-info/
dist/
build/
*.manifest
*.spec

# Pipenv & Poetry
Pipfile.lock
poetry.lock

# Django stuff:
python_services/db.sqlite3
python_services/*.sqlite3
python_services/media/
python_services/staticfiles/
