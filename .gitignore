# ========== FRONTEND/ (Node.js, Vite, React etc) ==========
frontend/node_modules/
frontend/.turbo/
frontend/.next/
frontend/.nuxt/
frontend/.vite/
frontend/.cache/
frontend/dist/
frontend/build/
frontend/.parcel-cache/

# Vite/React build outputs
frontend/*.local
frontend/.env.local
frontend/.env.production
frontend/.env.development

# Lockfiles (choose one if not using both)
frontend/package-lock.json
frontend/yarn.lock
frontend/pnpm-lock.yaml

# ========== BACKEND/ (Python/Django/Node if hybrid) ==========
backend/__pycache__/
backend/*.py[cod]
backend/node_modules/
backend/.env
backend/*.sqlite3
backend/media/
backend/staticfiles/

python_services/venv

